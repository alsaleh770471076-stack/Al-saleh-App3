{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Stores details of incoming (وارد) and outgoing (منصرف) transactions.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["inward", "outward"], "description": "Transaction type" },
        "amount": { "type": "number", "description": "Transaction amount in SR" },
        "category": { "type": "string", "description": "Category (e.g., customers, growers, transport)" },
        "description": { "type": "string", "description": "Details about the transaction" },
        "date": { "type": "string", "format": "date-time", "description": "Transaction date" },
        "createdBy": { "type": "string", "description": "UID of the user who recorded this" }
      },
      "required": ["type", "amount", "category", "date", "createdBy"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Stores stock levels for different items in the warehouse.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Item name" },
        "quantity": { "type": "number", "description": "Current stock quantity" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., cartons)" }
      },
      "required": ["name", "quantity", "unit"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transaction history."
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Warehouse stock levels."
    }
  }
}
